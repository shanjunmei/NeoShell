<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*" Name="NeoShell" Language="1033" Version="0.1.0"
             Manufacturer="NeoShell" UpgradeCode="a1b2c3d4-e5f6-7890-abcd-ef1234567890">
        <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />
        <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <Feature Id="Complete" Title="NeoShell" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
        </Feature>

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFilesFolder">
                <Directory Id="INSTALLFOLDER" Name="NeoShell" />
            </Directory>
            <Directory Id="DesktopFolder" />
        </Directory>

        <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
            <Component Id="MainExecutable" Guid="*">
                <File Id="neoshell.exe" Source="target\release\neoshell.exe" KeyPath="yes" />
            </Component>
        </ComponentGroup>
    </Product>
</Wix>
